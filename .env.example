# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key
SUPABASE_SERVICE_KEY=eyJ...tu-service-key

# DeepSeek Chatbot (opcional)
DEEPSEEK_API_KEY=sk-...tu-api-key

# Google AI Studio / Gemini Chatbot (opcional — si se configura se activa la IA real gratis!)
GEMINI_API_KEY=AIzaSy...tu-api-key-de-google-ai-studio

# Cloudinary (para subir fotos desde el admin)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
